# NoorGrid environment variables
# Copy this file to .env and fill in your values.

# TomTom API key (optional — reserved for future map enhancements)
TOMTOM_API_KEY=your_tomtom_api_key_here

# Backend base URL consumed by the Streamlit frontend
# Change to the deployed backend URL in production
BACKEND_URL=http://localhost:8000

# NVIDIA NIM API key for the RAG chatbot and report generation
# Get one at https://integrate.api.nvidia.com/
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# CORS allowed origins for the FastAPI backend (JSON list).
# Leave unset (or set to *) during local development.
# In production restrict to your frontend domain, e.g.:
#   CORS_ORIGINS=["https://noorgrid.steg.tn"]
CORS_ORIGINS=
